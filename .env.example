# Puerto en el que correrá el servidor API
PORT=3000

# Orígenes CORS permitidos (separados por coma)
# Hub (3001), ShopFlow (3003), Workify (3004) y otros frontends
CORS_ORIGIN=http://localhost:3001,http://localhost:3003,http://localhost:3004,http://localhost:3005

# URL de conexión a Neon PostgreSQL
# Obtén tu connection string desde: https://console.neon.tech
# Formato: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# JWT: obligatorio en producción. Nunca subas valores reales al repositorio.
# Genera un secreto seguro: openssl rand -base64 32
JWT_SECRET=your-secret-change-in-production
JWT_EXPIRES_IN=7d

# URL del servicio Database API (opcional, si usas otro servicio)
# Si tu API hace requests HTTP a otro servicio de database, configura esta variable
DATABASE_API_URL=http://localhost:3002

# Entorno de ejecución
NODE_ENV=development